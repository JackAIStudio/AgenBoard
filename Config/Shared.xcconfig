// 真机标识符由开发者在 Xcode 中选择的 Team 自动派生。
AGENBOARD_IDENTIFIER_SUFFIX = $(DEVELOPMENT_TEAM)

// 模拟器不需要签名，使用稳定的公开标识符。
AGENBOARD_IDENTIFIER_SUFFIX[sdk=iphonesimulator*] = simulator

AGENBOARD_APP_BUNDLE_IDENTIFIER = dev.agenboard.$(AGENBOARD_IDENTIFIER_SUFFIX)
AGENBOARD_KEYBOARD_BUNDLE_IDENTIFIER = dev.agenboard.$(AGENBOARD_IDENTIFIER_SUFFIX).keyboard
AGENBOARD_APP_GROUP_IDENTIFIER = group.dev.agenboard.$(AGENBOARD_IDENTIFIER_SUFFIX)
